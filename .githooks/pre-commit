#!/bin/bash
set -eu

# -----------------------------------------------------------------------------
# 1. Branch-name guard: refuse direct commits on main / develop (personal habit).
# -----------------------------------------------------------------------------
branch="$(git symbolic-ref HEAD 2>/dev/null)" || "$(git describe --contains --all HEAD)"

if [[ ${branch} =~ \/*main$ ]] || [[ ${branch} =~ \/*develop$ ]]; then
    echo "Can't commit on branch whose name contains main or develop (use a feature branch + PR)."
    exit 1
fi

# -----------------------------------------------------------------------------
# 2. Anonymity scan: refuse commits that introduce personal identifiers or
#    operator-internal stack names. The _template-prototype variant runs the
#    same PCRE pattern the disabled `.github/workflows/anon-check.yml` would
#    use, executed locally via the portable scanner. Staged files only — the
#    hook stays fast.
# -----------------------------------------------------------------------------
REPO_ROOT="$(git rev-parse --show-toplevel)"
SCANNER="${REPO_ROOT}/.tooling/local-ci/anon-scan.sh"

if [ -x "${SCANNER}" ]; then
    staged="$(git diff --cached --name-only --diff-filter=ACMRT)"
    if [ -n "${staged}" ]; then
        abs_staged=""
        while IFS= read -r f; do
            [ -z "${f}" ] && continue
            abs_staged="${abs_staged}${REPO_ROOT}/${f}"$'\n'
        done <<< "${staged}"
        ANON_SCAN_PATHS="${abs_staged}" bash "${SCANNER}"
    fi
else
    echo "warning: ${SCANNER} not found / not executable; skipping anon scan."
fi

# -----------------------------------------------------------------------------
# 3. Secret scan via gitleaks (= staged files only, fast). Catches accidental
#    `password = "..."` / API key paste / private key blob commits before they
#    leave the working tree. `gitleaks protect --staged` is the lightweight
#    pre-commit mode (= no history scan, just the diff).
# -----------------------------------------------------------------------------
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --redact --no-banner 2>&1; then
        echo ""
        echo "gitleaks found secrets in staged files. Remove them or commit with"
        echo "--no-verify only if you have verified the match is a false positive."
        exit 1
    fi
else
    echo "warning: gitleaks not installed; skipping secret scan." \
         "Install: brew install gitleaks  (or apt install gitleaks on Ubuntu)"
fi
